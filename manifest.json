{
  "manifest_version": 3,
  "name": "MyCursor",
  "version": "1.0",

  "icons": {
    "128": "images/favicon/favicon_300.png"
  },

  "action": {
    "default_icon": "images/favicon/favicon_300.png"
  },

  "permissions": ["storage", "contextMenus"],

  "options_ui": {
    "page": "option/option.html",
    "open_in_tab": true
  },

  "host_permissions": ["<all_urls>"],

  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["settings.js", "content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ]
}
